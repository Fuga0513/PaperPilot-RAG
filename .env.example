# PaperPilot-RAG local development environment example.
# Copy this file to .env and fill in real secrets locally.
# Do not commit .env.

# ===== LLM =====
ARK_API_KEY=your_api_key_here
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL=qwen-plus
GRADE_MODEL=qwen-plus
FAST_MODEL=qwen-plus

# ===== Embedding =====
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
DENSE_EMBEDDING_DIM=1024

# ===== Rerank (optional; leave empty to skip rerank) =====
RERANK_MODEL=
RERANK_BINDING_HOST=
RERANK_API_KEY=

# ===== Milvus =====
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=embeddings_collection

# ===== PostgreSQL / Redis =====
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/langchain_app
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=paperpilot
REDIS_CACHE_TTL_SECONDS=300

# ===== BM25 sparse retrieval =====
BM25_STATE_PATH=data/bm25_state.json

# ===== Auto-merging retrieval =====
AUTO_MERGE_ENABLED=true
AUTO_MERGE_THRESHOLD=2
LEAF_RETRIEVE_LEVEL=3

# ===== Auth =====
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
ADMIN_INVITE_CODE=paperpilot-admin-local
PASSWORD_PBKDF2_ROUNDS=310000

# ===== Optional tools =====
AMAP_WEATHER_API=https://restapi.amap.com/v3/weather/weatherInfo
AMAP_API_KEY=
